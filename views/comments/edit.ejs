<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit comment</title>
</head>

<body>
    <h1>Edit your comment</h1>
    <form action="/comments/<%= comment.id %>?_method=PATCH" method="post">
        <label for="comment">Enter Comment:</label> <br>
        <textarea name="comment" id="comment" rows="5" cols="30" placeholder="enter comment">
        <%= comment.comment%>
        </textarea> <br>
        <button type="submit">Save</button>
    </form>

    <a href="/comments">Back to Comment</a>
</body>

</html>